# =========================================
# Backend (FastAPI) - Production
# =========================================
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

QWEN_CHAT_MODEL=qwen-flash
QWEN_ENABLE_THINKING=false
QWEN_CHAT_MAX_TOKENS=110
QWEN_CHAT_TEMPERATURE=0.2
QWEN_CHAT_TOP_P=0.7

QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_DEFAULT_VOICE=Cherry

QWEN_OMNI_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_OMNI_REALTIME_DEFAULT_VOICE=Tina
QWEN_OMNI_REALTIME_VI_VOICE=Hana
QWEN_OMNI_REALTIME_TRANSCRIPTION_MODEL=gummy-realtime-v1
QWEN_OMNI_REALTIME_VAD_THRESHOLD=0.72
QWEN_OMNI_REALTIME_SILENCE_MS=1000
QWEN_OMNI_REALTIME_PREFIX_PADDING_MS=400
QWEN_SYSTEM_PROMPT=You are Pulse, a fast voice assistant. Reply in the users language and keep spoken answers short and natural.

# Put your real production web origins here.
# Example:
# CORS_ORIGINS=https://car-match-nine.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=https://car-match-nine.vercel.app

# =========================================
# Vite frontend (src/) - Production
# =========================================
# Keep API base relative on production so frontend calls same-origin /api.
# If omitted, app already defaults to /api.
VITE_API_BASE_URL=/api

# IMPORTANT:
# Do NOT set localhost websocket values on production.
# Leave empty to auto-derive from same-origin /api/realtime, OR set a real public wss endpoint.
# VITE_REALTIME_WS_URL=wss://your-realtime-host.example.com/realtime

VITE_QWEN_API_KEY=your_dashscope_api_key_here
VITE_QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
VITE_QWEN_MODEL=qwen-flash

# =========================================
# Optional legacy Next.js vars (not required for current Vite web app)
# =========================================
# API_BASE_URL=
# NEXT_PUBLIC_REALTIME_WS_URL=
# NEXT_PUBLIC_QWEN_API_KEY=
# NEXT_PUBLIC_QWEN_API_BASE_URL=
# NEXT_PUBLIC_QWEN_MODEL=
