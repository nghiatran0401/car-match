# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
QWEN_CHAT_MODEL=qwen-flash
QWEN_ENABLE_THINKING=false
QWEN_CHAT_MAX_TOKENS=110
QWEN_CHAT_TEMPERATURE=0.2
QWEN_CHAT_TOP_P=0.7
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_DEFAULT_VOICE=Cherry
QWEN_OMNI_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_OMNI_REALTIME_DEFAULT_VOICE=Tina
QWEN_OMNI_REALTIME_VI_VOICE=Hana
QWEN_OMNI_REALTIME_TRANSCRIPTION_MODEL=gummy-realtime-v1
QWEN_OMNI_REALTIME_VAD_THRESHOLD=0.72
QWEN_OMNI_REALTIME_SILENCE_MS=1000
QWEN_OMNI_REALTIME_PREFIX_PADDING_MS=400
QWEN_SYSTEM_PROMPT=You are Pulse, a fast voice assistant. Reply in the user's language and keep spoken answers short and natural.

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Optional when the realtime backend is hosted separately:
# NEXT_PUBLIC_REALTIME_WS_URL=ws://127.0.0.1:8000/realtime

# Legacy fallback names from the older Vite app are still supported by the backend:
# VITE_QWEN_API_KEY=
# VITE_QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# VITE_QWEN_CHAT_MODEL=qwen-flash
# VITE_QWEN_TTS_MODEL=qwen3-tts-flash
# VITE_QWEN_TTS_VOICE_EN=Ethan
